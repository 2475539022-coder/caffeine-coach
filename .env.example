# Server-side LLM provider used by /api/personalized-explanation.
LLM_PROVIDER="qwen"

# OpenAI-compatible chat completions model name.
LLM_MODEL="your-model-name"

# OpenAI-compatible API base URL, without a trailing slash if possible.
LLM_BASE_URL="https://your-provider-base-url"

# Server-side API key. Never expose this to browser code.
LLM_API_KEY="your-server-side-api-key"

# Optional: Preview smoke tests only.
TEST_API_BASE_URL="https://your-preview-url"

# Optional: Vercel Preview Deployment Protection automation bypass for tests only.
VERCEL_AUTOMATION_BYPASS_SECRET="your-vercel-automation-bypass-secret"
